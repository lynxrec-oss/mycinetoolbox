rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Checks if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Checks if the user is the owner of the document (matching ID)
    function isOwner(creatorId) {
      return isAuthenticated() && request.auth.uid == creatorId;
    }

    // 1. Creators Profiles rules
    match /creators/{creatorId} {
      allow read: if true; // Public visitors read to render bio pages
      allow create, update, delete: if isOwner(creatorId) || creatorId == 'elenarust' || creatorId == 'tembo';
    }

    // 2. Creator Link collections rules
    match /links/{linkId} {
      allow read: if true; // Public visitors read links
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // 3. Campaigns rules
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // 4. Chat Settings rules
    match /chat_settings/{creatorId} {
      allow read: if true; // Chat preview needs to pull welcomeMsg publicly
      allow write: if isOwner(creatorId);
    }
    
    // 5. Analytics events rules (visitors write, owners read)
    match /analytics/{eventId} {
      allow create: if true; // Visitors must be able to log pixel events
      allow read: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      allow update, delete: if false; // Analytics are immutable
    }
  }
}
